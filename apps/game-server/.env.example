# Game Server — copy to .env and fill in values

GAME_SERVER_PORT=2567

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ao
DATABASE_PASSWORD=ao_dev
DATABASE_NAME=ao

# Option 1: provide a single connection string (Neon) including sslmode=require
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option 2: provide separate vars and enable SSL
# DATABASE_SSL=true

# JWT — change this to a long random string in production
JWT_SECRET=ao-dev-secret-change-in-prod

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
